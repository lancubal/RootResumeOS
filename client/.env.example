# For local development
NEXT_PUBLIC_API_URL=http://localhost:3001

# For Production (Vercel)
# NEXT_PUBLIC_API_URL=https://api.your-domain.com

# Session persistence across page refreshes/navigation.
# Set to 'false' during development so every refresh starts a clean container.
# Leave unset or set to 'true' in production.
NEXT_PUBLIC_PERSIST_SESSION=false

# Resend — get your key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email address that receives contact form submissions
CONTACT_TO_EMAIL=lunalancuba.sistemas@gmail.com
